# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Password to access admin commands in the bot (send /login <password>)
ADMIN_PASSWORD=my_secret_password

# Maximum price in USD (default: 350)
MAX_PRICE_USD=350

# How often to check for new ads, in minutes (default: 10)
CHECK_INTERVAL_MINUTES=10
